# Minimal Sway config used only to host gtkgreet.
# gtkgreet exits after authentication; then this greeter compositor exits too.

output * bg #000000 solid_color

exec "gtkgreet -l -c 'dbus-run-session sway --unsupported-gpu'; swaymsg exit"

bindsym Mod4+Shift+e exec swaynag \
    -t warning \
    -m 'Power menu' \
    -b 'Poweroff' 'systemctl poweroff' \
    -b 'Reboot' 'systemctl reboot'
