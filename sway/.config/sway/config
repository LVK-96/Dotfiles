set $mod Mod4
set $terminal ghostty
set $menu rofi -show combi -combi-modes "drun,window,run"
set $lock ~/.config/sway/lock.sh
set $screenshot ~/.config/sway/screenshot.sh
set $nightlight ~/.config/sway/wlsunset-toggle.sh

xwayland enable

seat seat0 xcursor_theme Adwaita 24
exec_always {
    gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita'
    gsettings set org.gnome.desktop.interface icon-theme 'Adwaita'
    gsettings set org.gnome.desktop.interface cursor-theme 'Adwaita'
    gsettings set org.gnome.desktop.interface font-name 'Adwaita Sans 11'
    gsettings set org.gnome.desktop.interface document-font-name 'Adwaita Sans 11'
    gsettings set org.gnome.desktop.interface monospace-font-name 'AdwaitaMono Nerd Font 11'
    gsettings set org.gnome.desktop.interface color-scheme 'default'
}

client.focused          #268bd2 #268bd2 #fdf6e3 #268bd2 #268bd2
client.focused_inactive #93a1a1 #93a1a1 #fdf6e3 #93a1a1 #93a1a1
client.urgent           #dc322f #dc322f #fdf6e3 #dc322f #dc322f

floating_modifier $mod
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

# Outputs vary between machines. Start generic, then add per-output rules or
# kanshi profiles after checking names with: swaymsg -t get_outputs
output * bg #000000 solid_color

input type:keyboard {
    repeat_delay 200
    repeat_rate 75
    xkb_layout "us"
    xkb_options "ctrl:nocaps"
    xkb_variant "altgr-intl"
}

input type:touchpad {
    tap enabled
    dwt enabled
    middle_emulation enabled
}

bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev

bindsym $mod+Return exec $terminal
bindsym $mod+Shift+q kill
bindsym $mod+d exec $menu

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+Control+h split h
bindsym $mod+Control+v split v

bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Match physical displays by their EDID identity instead of connector names
# like DP-6/DP-7, which can change after reconnecting docks/cables.
set $main_output "Lenovo Group Limited LEN T27q-20 VNA7RW75"
set $side_output "Dell Inc. DELL U2414H 9TG464983G9L"
set $laptop_output "LG Display 0x06AA Unknown"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

workspace $ws1 output $main_output $side_output $laptop_output
workspace $ws2 output $main_output $side_output $laptop_output
workspace $ws3 output $main_output $side_output $laptop_output
workspace $ws4 output $main_output $side_output $laptop_output
workspace $ws5 output $main_output $side_output $laptop_output
workspace $ws6 output $side_output $main_output $laptop_output
workspace $ws7 output $side_output $main_output $laptop_output
workspace $ws8 output $side_output $main_output $laptop_output
workspace $ws9 output $side_output $main_output $laptop_output
workspace $ws10 output $side_output $main_output $laptop_output

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exit

mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

bindsym ctrl+$mod+l exec $lock lock
bindsym Print exec $screenshot area
bindsym Shift+Print exec $screenshot screen
bindsym $mod+g exec $nightlight toggle

# Volume
bindsym XF86AudioRaiseVolume exec wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Microphone
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

for_window [app_id="pavucontrol"] {
    floating enable
    resize set 800px 600px
}
for_window [app_id="qalculate"] floating enable
# Firefox PiP reports stable browser identifiers, so match both Wayland and
# XWayland variants explicitly.
for_window [app_id="firefox" title="(?i)^picture(?:-in-| in )picture$"] {
    floating enable
    resize set 800px 450px
}
for_window [class="(?i)^firefox$" title="(?i)^picture(?:-in-| in )picture$"] {
    floating enable
    resize set 800px 450px
}
# Brave PiP currently exposes an empty app_id in Sway, so title match is the
# only reliable criteria available here.
for_window [title="(?i)^picture in picture$"] {
    floating enable
    resize set 800px 450px
}

exec_always dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_RUNTIME_DIR XDG_CURRENT_DESKTOP XDG_SESSION_TYPE DBUS_SESSION_BUS_ADDRESS
exec_always --no-startup-id ~/.config/sway/autostart.sh
